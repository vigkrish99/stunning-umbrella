# ===========================================
# HELIX BACKEND - ENVIRONMENT VARIABLES
# ===========================================

# MongoDB
MONGODB_URI=mongodb://localhost:27017/helix-gases_production

# TrackAbout API
TRACKABOUT_USER=<YOUR_TRACKABOUT_USERNAME>
TRACKABOUT_PASS=
TRACKABOUT_API_KEY=<YOUR_TRACKABOUT_API_KEY>
TRACKABOUT_APP_INSTANCE_ID=helix-gases-app-001

# Zoho Books API
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ACCESS_TOKEN=
ZOHO_ORG_ID=<REDACTED_ZOHO_ORG_ID>
ZOHO_DOMAIN=in

# Server
PORT=4000
NODE_ENV=development

# Logging
LOG_LEVEL=info
